<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>Akosombo International School | Truth is our Light</title>
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Open Sans', sans-serif;
      background: #f4f9ff;
      color: #1e2a3e;
      line-height: 1.5;
    }
    h1, h2, h3, h4, .nav-links a, .logo h1 {
      font-family: 'Poppins', sans-serif;
      font-weight: 600;
    }
    .container {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 24px;
    }
    /* header */
    header {
      background: #0b2b3b;
      color: white;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }
    .header-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      padding: 18px 24px;
      border-bottom: 1px solid #2c4b5e;
    }
    .logo h1 {
      font-size: 1.8rem;
      letter-spacing: -0.5px;
    }
    .logo p {
      font-size: 0.85rem;
      color: #ffd966;
    }
    .motto {
      background: #ffcd4a;
      color: #0b2b3b;
      padding: 6px 14px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.85rem;
    }
    .navbar {
      background: #0f3b4e;
      padding: 0 24px;
      overflow-x: auto;
      white-space: nowrap;
    }
    .nav-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      list-style: none;
      gap: 4px;
      padding: 8px 0;
    }
    .nav-links li a {
      display: inline-block;
      padding: 12px 16px;
      color: #f0f4f8;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: 0.2s;
      border-radius: 40px;
    }
    .nav-links li a:hover, .nav-links li a.active {
      background: #ffcd4a;
      color: #0b2b3b;
    }
    /* page content */
    .page-content {
      min-height: 65vh;
      background: white;
      margin: 40px 24px;
      border-radius: 32px;
      box-shadow: 0 20px 35px rgba(0,0,0,0.05);
      padding: 40px 32px;
      transition: all 0.2s;
    }
    .page {
      display: none;
      animation: fadeIn 0.4s ease;
    }
    .active-page {
      display: block;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(12px);}
      to { opacity: 1; transform: translateY(0);}
    }
    h2 {
      font-size: 2rem;
      margin-bottom: 1.5rem;
      color: #0b2b3b;
      border-left: 6px solid #ffcd4a;
      padding-left: 20px;
    }
    h3 {
      margin: 1.5rem 0 0.8rem;
      color: #1f4e6e;
    }
    .grid-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
      gap: 28px;
      margin: 30px 0;
    }
    .card {
      background: #ffffff;
      border-radius: 28px;
      padding: 24px 20px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.05);
      border: 1px solid #eef2f8;
      transition: all 0.3s;
    }
    .card:hover {
      transform: translateY(-6px);
      border-color: #ffcd4a;
      box-shadow: 0 20px 25px -12px rgba(0,0,0,0.1);
    }
    .card i {
      font-size: 2.5rem;
      color: #e6a017;
      margin-bottom: 15px;
    }
    .alumni-list {
      display: flex;
      flex-wrap: wrap;
      gap: 24px;
      margin-top: 20px;
    }
    .alumni-card {
      background: #fef7e0;
      border-radius: 24px;
      padding: 20px;
      width: calc(33% - 16px);
      min-width: 220px;
      border-left: 5px solid #ffcd4a;
      transition: 0.2s;
    }
    .news-item, .event-item {
      background: #f5f9ff;
      border-radius: 20px;
      padding: 20px;
      margin-bottom: 20px;
      border-left: 5px solid #ffcd4a;
    }
    .contact-info {
      display: flex;
      flex-wrap: wrap;
      gap: 30px;
      margin: 30px 0;
    }
    .contact-details, .contact-form {
      flex: 1;
      background: #f8fafc;
      padding: 28px;
      border-radius: 28px;
    }
    input, select, textarea {
      width: 100%;
      padding: 12px 16px;
      margin: 8px 0 18px;
      border: 1px solid #cfdfe8;
      border-radius: 60px;
      font-family: inherit;
      background: white;
    }
    textarea {
      border-radius: 24px;
    }
    button {
      background: #0b2b3b;
      color: white;
      border: none;
      padding: 12px 28px;
      border-radius: 40px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.2s;
    }
    button:hover {
      background: #ffcd4a;
      color: #0b2b3b;
    }
    .map-container {
      border-radius: 28px;
      overflow: hidden;
      margin: 30px 0;
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }
    iframe {
      width: 100%;
      height: 380px;
      border: 0;
    }
    .index-number-card {
      background: #e9f3e9;
      padding: 16px;
      border-radius: 20px;
      margin-top: 20px;
      text-align: center;
      font-weight: bold;
      font-size: 1.2rem;
      border: 1px dashed #2c7a2c;
    }
    footer {
      background: #0b2b3b;
      color: #cfdfe8;
      padding: 40px 24px 20px;
      text-align: center;
    }
    .footer-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      max-width: 1200px;
      margin: auto;
      gap: 30px;
    }
    .footer-col h4 {
      color: #ffcd4a;
      margin-bottom: 15px;
    }
    .copyright {
      border-top: 1px solid #2c4b5e;
      margin-top: 30px;
      padding-top: 20px;
      font-size: 0.85rem;
    }
    @media (max-width: 780px) {
      .nav-links li a { padding: 8px 12px; font-size: 0.75rem; }
      .page-content { padding: 24px 20px; margin: 20px 16px; }
      .alumni-card { width: 100%; }
    }
  </style>
</head>
