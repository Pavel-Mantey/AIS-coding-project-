  <title>Akosombo International School | Truth is our Light</title>
  <!-- Font Awesome 6 (free) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Google Fonts: Poppins & Open Sans -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Open Sans', sans-serif;
      background: #f8fafc;
      color: #1e2a3e;
      line-height: 1.5;
    }

    /* Typography */
    h1, h2, h3, h4, .nav-links a, .logo h1 {
      font-family: 'Poppins', sans-serif;
      font-weight: 600;
    }

    .container {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* Header & Navigation */
    header {
      background: #0b2b3b;
      color: white;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .header-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      padding: 18px 24px;
      border-bottom: 1px solid #2c4b5e;
    }

    .logo h1 {
      font-size: 1.8rem;
      letter-spacing: -0.5px;
    }

    .logo p {
      font-size: 0.85rem;
      color: #ffd966;
      font-weight: 500;
    }

    .motto {
      background: #ffcd4a;
      color: #0b2b3b;
      padding: 6px 14px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.85rem;
    }

    /* Navbar */
    .navbar {
      background: #0f3b4e;
      padding: 0 24px;
    }

    .nav-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      list-style: none;
      gap: 4px;
    }

    .nav-links li a {
      display: inline-block;
      padding: 14px 18px;
      color: #f0f4f8;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      transition: 0.2s;
      border-radius: 6px;
    }

    .nav-links li a:hover, .nav-links li a.active {
      background: #ffcd4a;
      color: #0b2b3b;
    }

    /* main content */
    .page-content {
      min-height: 65vh;
      background: white;
      margin: 40px 24px;
      border-radius: 28px;
      box-shadow: 0 12px 30px rgba(0,0,0,0.05);
      padding: 40px 32px;
      transition: all 0.2s;
    }

    .page {
      display: none;
      animation: fade 0.3s ease;
    }

    .active-page {
      display: block;
    }

    @keyframes fade {
      from { opacity: 0; transform: translateY(8px);}
      to { opacity: 1; transform: translateY(0);}
    }

    /* page styling */
    h2 {
      font-size: 2rem;
      margin-bottom: 1rem;
      color: #0b2b3b;
      border-left: 5px solid #ffcd4a;
      padding-left: 20px;
    }

    h3 {
      margin: 1.5rem 0 0.8rem 0;
      color: #1f4e6e;
    }

    .grid-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 28px;
      margin: 30px 0;
    }

    .card {
      background: #ffffff;
      border-radius: 24px;
      padding: 20px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
      border: 1px solid #e9eef3;
      transition: transform 0.2s;
    }

    .card:hover {
      transform: translateY(-5px);
      border-color: #ffcd4a;
    }

    .card i {
      font-size: 2.2rem;
      color: #ffb347;
      margin-bottom: 12px;
    }

    .alumni-list {
      display: flex;
      flex-wrap: wrap;
      gap: 24px;
      margin-top: 20px;
    }

    .alumni-card {
      background: #fef9e8;
      border-radius: 20px;
      padding: 18px;
      width: calc(33% - 16px);
      min-width: 220px;
      border-left: 5px solid #ffcd4a;
    }

    .news-item, .event-item {
      background: #f5f9ff;
      border-radius: 18px;
      padding: 20px;
      margin-bottom: 20px;
      border-left: 4px solid #ffcd4a;
    }

    .contact-info {
      display: flex;
      flex-wrap: wrap;
      gap: 30px;
      margin: 30px 0;
    }

    .contact-details {
      flex: 1;
      background: #f0f4fa;
      padding: 25px;
      border-radius: 24px;
    }

    .contact-form {
      flex: 1;
      background: white;
      border: 1px solid #ddd;
      padding: 25px;
      border-radius: 24px;
    }

    input, textarea {
