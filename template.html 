<script>
  // PAGE SWITCHING LOGIC
  const pages = document.querySelectorAll('.page');
  const navLinks = document.querySelectorAll('.nav-links li a');

  function showPage(pageId) {
    pages.forEach(page => {
      page.classList.remove('active-page');
      if (page.id === pageId) {
        page.classList.add('active-page');
      }
    });
    // update active class on navbar
    navLinks.forEach(link => {
      const linkPage = link.getAttribute('data-page');
      if (linkPage === pageId) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  navLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const pageId = link.getAttribute('data-page');
      if (pageId) {
        showPage(pageId);
      } else {
        // fallback if data-page missing
      }
    });
  });

  // Also handle footer quick links alumni page
  const footerAlumni = document.querySelector('a[data-page="alumni"]');
  if(footerAlumni) {
    footerAlumni.addEventListener('click', (e) => {
      e.preventDefault();
      showPage('alumni');
    });
  }
  // For any other potential data-page in footer (admissions not built, but just redirect home)
  const footerAdmission = document.querySelector('a[data-page="admissions"]');
  if(footerAdmission) {
    footerAdmission.addEventListener('click', (e) => {
      e.preventDefault();
      alert('Admissions for 2026/2027 academic year will open in September. Contact admissions office for details.');
    });
  }

  // Contact form demo (prevent actual submit)
  const contactForm = document.getElementById('demo-contact');
  if(contactForm) {
    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('Thank you for reaching out! Our admissions team will respond within 2 business days. (Demo mode)');
      contactForm.reset();
    });
  }

  // Additional protocol: set default home if URL hash is empty, but we already have active home
  // ensure that if someone clicks brand etc
  const logoTitle = document.querySelector('.logo');
  if(logoTitle) {
    logoTitle.addEventListener('click', () => showPage('home'));
  }
</script>
